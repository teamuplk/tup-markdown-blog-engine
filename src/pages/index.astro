---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import FeaturedCarousel from '../components/FeaturedCarousel.astro';
import { collectTaxonomyItems, getPublishedPosts, getFeaturedPosts } from '../lib/blog';
import { siteConfig } from '../data/site';

const posts = await getPublishedPosts();
const featuredPosts = siteConfig.featuredPosts ? await getFeaturedPosts(siteConfig.featuredPosts) : [];
const latestPosts = posts.slice(0, 3);
const categories = collectTaxonomyItems(posts, (post) => [post.data.category]).slice(0, 6);
const allTags = collectTaxonomyItems(posts, (post) => post.data.tags);
const configuredTagSlugs = siteConfig.home.tagsSection.showTags;
const tags = configuredTagSlugs && configuredTagSlugs.length > 0
  ? allTags.filter((tag) => configuredTagSlugs.includes(tag.slug)).slice(0, 6)
  : allTags.slice(0, 6);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  {featuredPosts.length > 0 && (
    <section class="mb-12">
      <FeaturedCarousel
        posts={featuredPosts}
        readMore={siteConfig.home.featuredSection.readMore}
      />
    </section>
  )}

  <!-- <section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
    <div class="space-y-6">
      <p class="inline-flex rounded-full border border-[var(--brand-border)] bg-[var(--brand-soft)] px-4 py-2 text-sm font-semibold text-[var(--brand)]">
        {siteConfig.home.badge}
      </p>

      <h1 class="max-w-3xl text-5xl font-semibold tracking-tight text-[var(--brand-accent)] sm:text-6xl">{siteConfig.home.title}</h1>

      <p class="max-w-2xl text-lg leading-8 text-[var(--brand-muted)]">{siteConfig.home.description}</p>

      <div class="flex flex-wrap gap-3">
        <a
          href={siteConfig.home.primaryCta.href}
          class="rounded-full bg-[var(--brand-accent)] px-5 py-3 text-sm font-semibold text-[var(--brand-foreground)] transition hover:opacity-90"
        >
          {siteConfig.home.primaryCta.label}
        </a>
        <a
          href={siteConfig.home.secondaryCta.href}
          class="rounded-full border border-[var(--brand-border)] bg-[var(--brand-surface)] px-5 py-3 text-sm font-semibold text-[var(--brand-foreground-color)] transition hover:border-[var(--brand)] hover:text-[var(--brand)]"
        >
          {siteConfig.home.secondaryCta.label}
        </a>
      </div>
    </div>

    <div class="grid gap-4 rounded-3xl border border-[var(--brand-border)]/80 bg-[var(--brand-surface)]/90 p-6 shadow-sm sm:grid-cols-2">
      <div class="rounded-2xl bg-[var(--brand-accent)] p-5 text-[var(--brand-foreground)]">
        <p class="text-sm font-medium text-[var(--brand-foreground)]/75">{siteConfig.home.stats.postsLabel}</p>
        <p class="mt-4 text-4xl font-semibold">{posts.length}</p>
      </div>
      <div class="rounded-2xl bg-[var(--brand-soft)] p-5 text-[var(--brand-accent)]">
        <p class="text-sm font-medium text-[var(--brand)]">{siteConfig.home.stats.categoriesLabel}</p>
        <p class="mt-4 text-4xl font-semibold">{categories.length}</p>
      </div>
      <div class="rounded-2xl bg-[var(--brand-surface)] p-5 text-[var(--brand-accent)] ring-1 ring-[var(--brand-border)]">
        <p class="text-sm font-medium text-[var(--brand-muted)]">{siteConfig.home.stats.tagsLabel}</p>
        <p class="mt-4 text-4xl font-semibold">{tags.length}</p>
      </div>
      <div class="rounded-2xl bg-[var(--brand-background)] p-5 text-[var(--brand-accent)]">
        <p class="text-sm font-medium text-[var(--brand-muted)]">{siteConfig.home.stats.hostingLabel}</p>
        <p class="mt-4 text-lg font-semibold leading-7">{siteConfig.home.stats.hostingValue}</p>
      </div>
    </div>
  </section>-->

  <section class="mt-16 space-y-6">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--brand)]">{siteConfig.home.categoriesSection.eyebrow}</p>
        <h2 class="mt-2 text-3xl font-semibold tracking-tight text-[var(--brand-accent)]">{siteConfig.home.categoriesSection.title}</h2>
      </div>
      <a href="/categories/" class="text-sm font-semibold text-[var(--brand)] transition hover:opacity-80">
        {siteConfig.home.categoriesSection.ctaLabel}
      </a>
    </div>

    <div class="flex flex-wrap gap-3">
      {categories.map((category) => (
        <a
          href={`/categories/${category.slug}/`}
          class="rounded-full border border-[var(--brand-border)] bg-[var(--brand-surface)] px-4 py-2 text-sm font-medium text-[var(--brand-foreground-color)] transition hover:border-[var(--brand)] hover:bg-[var(--brand-soft)] hover:text-[var(--brand)]"
        >
          {category.label}
          <span class="ml-2 text-[var(--brand-muted)]">{category.count}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-16">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--brand)]">{siteConfig.home.latestSection.eyebrow}</p>
        <h2 class="mt-2 text-3xl font-semibold tracking-tight text-[var(--brand-accent)]">{siteConfig.home.latestSection.title}</h2>
      </div>
      <a href="/blog/" class="text-sm font-semibold text-[var(--brand)] transition hover:opacity-80">
        {siteConfig.home.latestSection.ctaLabel}
      </a>
    </div>

    <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  {tags.length > 0 && (
    <section class="mt-16 rounded-3xl border border-[var(--brand-border)]/80 bg-[var(--brand-surface)]/90 p-6 shadow-sm">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--brand)]">{siteConfig.home.tagsSection.eyebrow}</p>
          <h2 class="mt-2 text-3xl font-semibold tracking-tight text-[var(--brand-accent)]">{siteConfig.home.tagsSection.title}</h2>
        </div>
        <a href="/tags/" class="text-sm font-semibold text-[var(--brand)] transition hover:opacity-80">
          {siteConfig.home.tagsSection.ctaLabel}
        </a>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        {tags.map((tag) => (
          <a
            href={`/tags/${tag.slug}/`}
            class="rounded-full bg-[var(--brand-background)] px-4 py-2 text-sm font-medium text-[var(--brand-foreground-color)] transition hover:bg-[var(--brand-accent)] hover:text-[var(--brand-foreground)]"
          >
            {tag.label}
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
