---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTaxonomyItems, getPublishedPosts } from '../../lib/blog';
import { siteConfig } from '../../data/site';

const posts = await getPublishedPosts();
const categories = collectTaxonomyItems(posts, (post) => [post.data.category]);
---

<BaseLayout title={`Categories | ${siteConfig.title}`} description="Browse all categories from the TeamUp archive.">
  <section class="space-y-6">
    <div class="max-w-3xl space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-blue-700">Categories</p>
      <h1 class="text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Browse the content by category</h1>
      <p class="text-lg leading-8 text-slate-600">
        Categories make the archive easy to scan and keep related posts grouped together.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((category) => (
        <a
          href={`/categories/${category.slug}/`}
          class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
        >
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-blue-700">Category</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">{category.label}</h2>
          <p class="mt-2 text-sm text-slate-500">{category.count} posts</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
