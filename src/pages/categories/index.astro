---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTaxonomyItems, getPublishedPosts } from '../../lib/blog';
import { siteConfig } from '../../data/site';

const posts = await getPublishedPosts();
const categories = collectTaxonomyItems(posts, (post) => [post.data.category]);
---

<BaseLayout title={`Categories | ${siteConfig.title}`} description={siteConfig.categoriesPage.metaDescription}>
  <section class="space-y-6">
    <div class="max-w-3xl space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--brand)]">{siteConfig.categoriesPage.eyebrow}</p>
      <h1 class="text-4xl font-semibold tracking-tight text-[var(--brand-accent)] sm:text-5xl">{siteConfig.categoriesPage.title}</h1>
      <p class="text-lg leading-8 text-[var(--brand-muted)]">{siteConfig.categoriesPage.description}</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((category) => (
        <a
          href={`/categories/${category.slug}/`}
          class="rounded-3xl border border-[var(--brand-border)]/80 bg-[var(--brand-surface)] p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
        >
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--brand)]">{siteConfig.categoriesPage.cardLabel}</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-[var(--brand-accent)]">{category.label}</h2>
          <p class="mt-2 text-sm text-[var(--brand-muted)]">{category.count} posts</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
