---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { render } from 'astro:content';
import { getPublishedPosts, getRelatedPosts } from '../../lib/blog';
import { slugify } from '../../lib/slug';
import { siteConfig } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const posts = await getPublishedPosts();
const slug = Astro.params.slug ?? '';
const post = posts.find((entry) => entry.id === slug);

if (!post) {
  throw new Error(`Post not found for slug: ${slug}`);
}

const { Content } = await render(post);
const relatedPosts = getRelatedPosts(post, posts);
const canonical = post.data.canonicalUrl ?? new URL(`/blog/${post.id}/`, siteConfig.url).toString();
const description = post.data.seoDescription ?? post.data.description;
---

<BaseLayout title={`${post.data.title} | ${siteConfig.title}`} description={description} canonical={canonical} ogType="article">
  <article class="rounded-3xl border border-slate-200/80 bg-white/90 p-6 shadow-sm sm:p-8 lg:p-10">
    <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">
      <a
        href={`/categories/${slugify(post.data.category)}/`}
        class="rounded-full bg-blue-50 px-3 py-1 text-blue-700 transition hover:bg-blue-100"
      >
        {post.data.category}
      </a>
      <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toDateString()}</time>
      {post.data.updatedDate && <span>Updated {post.data.updatedDate.toDateString()}</span>}
    </div>

    <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">{post.data.title}</h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">
      {post.data.description.replace(/&#(\d+);/g, (_, code) => String.fromCharCode(parseInt(code, 10)))
        .replace(/&hellip;/g, '…')
        .replace(/&mdash;/g, '—')
        .replace(/&ndash;/g, '–')
        .replace(/&amp;/g, '&')
        .replace(/&lt;/g, '<')
        .replace(/&gt;/g, '>')
        .replace(/&quot;/g, '"')
        .replace(/&apos;/g, "'")}
    </p>

    {post.data.tags.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <a
            href={`/tags/${slugify(tag)}/`}
            class="rounded-full border border-slate-200 px-3 py-1 text-sm font-medium text-slate-600 transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700"
          >
            {tag}
          </a>
        ))}
      </div>
    )}

    <div class="mt-10 space-y-6 text-lg leading-8 text-slate-700 [&_a]:font-semibold [&_a]:text-blue-700 [&_a:hover]:underline [&_h2]:mt-10 [&_h2]:text-3xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:text-slate-950 [&_h3]:mt-8 [&_h3]:text-2xl [&_h3]:font-semibold [&_h3]:tracking-tight [&_h3]:text-slate-950 [&_p]:text-slate-700 [&_ul]:space-y-2 [&_ul]:pl-6 [&_ul]:text-slate-700 [&_ul]:list-disc [&_ol]:space-y-2 [&_ol]:pl-6 [&_ol]:text-slate-700 [&_ol]:list-decimal [&_blockquote]:border-l-4 [&_blockquote]:border-blue-200 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-slate-600 [&_code]:rounded [&_code]:bg-slate-100 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-sm [&_pre]:overflow-x-auto [&_pre]:rounded-2xl [&_pre]:bg-slate-950 [&_pre]:p-5 [&_pre]:text-sm [&_pre]:text-slate-100">
      <Content />
    </div>
  </article>

  {relatedPosts.length > 0 && (
    <section class="mt-16 space-y-6">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-blue-700">Related</p>
        <h2 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950">More posts like this</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {relatedPosts.map((relatedPost) => (
          <article class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm">
            <a href={`/blog/${relatedPost.id}/`} class="text-xl font-semibold text-slate-950 transition hover:text-blue-700">
              {relatedPost.data.title}
            </a>
            <p class="mt-3 text-sm leading-6 text-slate-600">{relatedPost.data.description}</p>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
