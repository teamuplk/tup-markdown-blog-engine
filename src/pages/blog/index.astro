---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchPosts from '../../components/SearchPosts.vue';
import { getPublishedPosts, toSearchItem } from '../../lib/blog';
import { siteConfig } from '../../data/site';

const posts = await getPublishedPosts();
const searchPosts = posts.map(toSearchItem);
---

<BaseLayout title={`Blog | ${siteConfig.title}`} description="Browse every TeamUp post and search the archive.">
  <section class="space-y-6">
    <div class="max-w-3xl space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-blue-700">Blog</p>
      <h1 class="text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">TeamUp archive</h1>
      <p class="text-lg leading-8 text-slate-600">
        Search posts by title, category, or description without needing a backend.
      </p>
    </div>

    <SearchPosts client:load posts={searchPosts} />
  </section>
</BaseLayout>
