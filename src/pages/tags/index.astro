---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTaxonomyItems, getPublishedPosts } from '../../lib/blog';
import { siteConfig } from '../../data/site';

const posts = await getPublishedPosts();
const tags = collectTaxonomyItems(posts, (post) => post.data.tags);
---

<BaseLayout title={`Tags | ${siteConfig.title}`} description={siteConfig.tagsPage.metaDescription}>
  <section class="space-y-6">
    <div class="max-w-3xl space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--brand)]">{siteConfig.tagsPage.eyebrow}</p>
      <h1 class="text-4xl font-semibold tracking-tight text-[var(--brand-accent)] sm:text-5xl">{siteConfig.tagsPage.title}</h1>
      <p class="text-lg leading-8 text-[var(--brand-muted)]">{siteConfig.tagsPage.description}</p>
    </div>

    <div class="flex flex-wrap gap-3">
      {tags.map((tag) => (
        <a
          href={`/tags/${tag.slug}/`}
          class="rounded-full border border-[var(--brand-border)] bg-[var(--brand-surface)] px-4 py-2 text-sm font-medium text-[var(--brand-foreground-color)] transition hover:border-[var(--brand)] hover:bg-[var(--brand-soft)] hover:text-[var(--brand)]"
        >
          {tag.label}
          <span class="ml-2 text-[var(--brand-muted)]">{tag.count}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
