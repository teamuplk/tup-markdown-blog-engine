---
import { siteConfig } from '../data/site';
---

<footer class="border-t border-[var(--brand-border)]/70 bg-[var(--brand-surface)]/70">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-2 px-4 py-8 text-center text-sm text-[var(--brand-muted)] sm:px-6 lg:px-8">
    <p><span class="font-semibold text-[var(--brand)]">{siteConfig.title}</span> is built with Free & Open Sourced <a href="https://github.com/teamuplk/tup-markdown-blog-engine" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-[var(--brand-border)] hover:decoration-[var(--brand)] transition">Blog Engine</a> powered by <a href="https://teamup.lk" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-[var(--brand-border)] hover:decoration-[var(--brand)] transition">TeamUp</a>.</p>
    <p>&copy; {new Date().getFullYear()} {siteConfig.title}. All rights reserved.</p>
  </div>
</footer>
