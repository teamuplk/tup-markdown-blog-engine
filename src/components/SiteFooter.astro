---
import { siteConfig } from '../data/site';
---

<footer class="border-t border-[var(--brand-border)]/70 bg-[var(--brand-surface)]/70">
  <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-8 text-sm text-[var(--brand-muted)] sm:px-6 lg:px-8">
    <p><span class="font-semibold text-[var(--brand)]">{siteConfig.title}</span> is built with Astro, Vue, Tailwind CSS, and Markdown content.</p>
    <p>Prepared for Cloudflare Pages deployment.</p>
  </div>
</footer>
