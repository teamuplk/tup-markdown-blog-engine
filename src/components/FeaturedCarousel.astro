---
import type { CollectionEntry } from 'astro:content';
import { formatDate, getPostSlug, decodeHtmlEntities } from '../lib/blog';

interface Props {
  posts: CollectionEntry<'blog'>[];
  readMore: string;
}

const { posts, readMore } = Astro.props;

function getHeroImageUrl(heroImage: string | undefined): string | null {
  if (!heroImage) return null;
  if (heroImage.startsWith('http')) return heroImage;
  if (heroImage.startsWith('/')) return heroImage;
  return `/content/uploads/${heroImage}`;
}

function decodeDesc(text: string): string {
  return text.replace(/&#(\d+);/g, (_, code) => String.fromCharCode(parseInt(code, 10)))
    .replace(/&hellip;/g, '…')
    .replace(/&mdash;/g, '—')
    .replace(/&ndash;/g, '–')
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&apos;/g, "'");
}
---

<section class="featured-carousel relative overflow-hidden rounded-3xl">
  <div class="carousel-container relative" data-posts={posts.length}>
    {posts.map((post, index) => {
      const heroImageUrl = getHeroImageUrl(post.data.heroImage);
      const hasHeroImage = !!heroImageUrl;
      const slideClass = hasHeroImage 
        ? 'carousel-slide active has-image' 
        : `carousel-slide ${index === 0 ? 'active' : ''}`;
      return (
        <div class={slideClass} data-index={index}>
          <a href={`/blog/${getPostSlug(post)}/`} class="block">
            <div class:list={[
              'relative min-h-[320px] md:min-h-[400px]',
              hasHeroImage && 'bg-cover bg-center'
            ]}
            {...hasHeroImage ? { style: `background-image: url('${heroImageUrl}')` } : {}}>
              <div class:list={[
                'absolute inset-0',
                hasHeroImage ? 'bg-gradient-to-br from-black/70 to-black/50' : 'bg-gradient-to-br from-blue-600 to-blue-400'
              ]}></div>
              {hasHeroImage && <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_120%,rgba(255,255,255,0.1),transparent_50%)]"></div>}
              <div class="relative h-full p-6 md:p-10">
                <div class="flex h-full flex-col justify-end px-8">
                  <div class="mb-3 flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.22em] text-white/75">
                    <span class="rounded-full bg-white/20 px-3 py-1">{post.data.category}</span>
                    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                  </div>
                  <h3 class="text-3xl font-semibold leading-tight text-white md:text-4xl">{post.data.title}</h3>
                  {post.data.description && (
                    <p class="mt-3 max-w-xl text-base leading-relaxed text-white/80">{decodeDesc(post.data.description)}</p>
                  )}
                  <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-white">
                    {readMore}
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          </a>
        </div>
      );
    })}
  </div>

  {posts.length > 1 && (
    <div class="absolute bottom-4 left-1/2 z-10 flex -translate-x-1/2 gap-2 md:bottom-6">
      {posts.map((_, index) => (
        <button
          class="carousel-dot h-2 w-2 rounded-full bg-white/40 transition-all hover:bg-white/70"
          data-index={index}
          aria-label={`Go to slide ${index + 1}`}
        ></button>
      ))}
    </div>
  )}

  {posts.length > 1 && (
    <>
      <button class="carousel-prev absolute left-4 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/20 p-2 text-white backdrop-blur-sm transition hover:bg-white/30 md:left-6" aria-label="Previous slide">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>
      <button class="carousel-next absolute right-4 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/20 p-2 text-white backdrop-blur-sm transition hover:bg-white/30 md:right-6" aria-label="Next slide">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </>
  )}
</section>

<style>
  .carousel-slide {
    display: none;
    animation: fadeIn 0.5s ease-in-out;
  }

  .carousel-slide.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .carousel-dot.active {
    width: 24px;
    border-radius: 9999px;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.querySelector('.carousel-container');
    if (!container) return;

    const slides = container.querySelectorAll('.carousel-slide');
    const dots = document.querySelectorAll('.carousel-dot');
    const prevBtn = document.querySelector('.carousel-prev');
    const nextBtn = document.querySelector('.carousel-next');
    const totalSlides = slides.length;

    if (totalSlides <= 1) return;

    let currentIndex = 0;
    let autoPlayInterval: number;

    function showSlide(index: number) {
      slides.forEach((slide, i) => {
        slide.classList.toggle('active', i === index);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === index);
      });
      currentIndex = index;
    }

    function nextSlide() {
      showSlide((currentIndex + 1) % totalSlides);
    }

    function prevSlide() {
      showSlide((currentIndex - 1 + totalSlides) % totalSlides);
    }

    function startAutoPlay() {
      autoPlayInterval = window.setInterval(nextSlide, 5000);
    }

    function stopAutoPlay() {
      clearInterval(autoPlayInterval);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        showSlide(parseInt(target.dataset.index || '0', 10));
        stopAutoPlay();
        startAutoPlay();
      });
    });

    prevBtn?.addEventListener('click', () => {
      prevSlide();
      stopAutoPlay();
      startAutoPlay();
    });

    nextBtn?.addEventListener('click', () => {
      nextSlide();
      stopAutoPlay();
      startAutoPlay();
    });

    showSlide(0);
    startAutoPlay();
  });
</script>