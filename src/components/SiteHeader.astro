---
import { siteConfig } from '../data/site';

const { currentPath = '/' } = Astro.props as { currentPath?: string };

const isActive = (href: string) => (href === '/' ? currentPath === '/' : currentPath.startsWith(href));

const isImageUrl = (value: string) => /\.(png|svg|jpe?g)$/i.test(value);
---

<header class="sticky top-0 z-40 border-b border-[var(--brand-border)]/70 bg-[var(--brand-surface)]/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
    <a href="/" class="flex items-center gap-3">
      {siteConfig.brandMark && (
        isImageUrl(siteConfig.brandMark) ? (
          <img src={siteConfig.brandMark} alt={siteConfig.title} class="h-11 w-auto object-contain max-h-8" />
        ) : (
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[var(--brand)] text-sm font-semibold text-[var(--brand-foreground)] shadow-lg shadow-slate-950/15">
            {siteConfig.brandMark}
          </span>
        )
      )}
      <span>
        <span class="block text-base font-semibold text-[var(--brand-foreground-color)]">{siteConfig.title}</span>
        <span class="block text-sm text-[var(--brand-muted)]">{siteConfig.description}</span>
      </span>
    </a>

    <nav class="flex flex-wrap items-center gap-2 text-sm font-medium text-[var(--brand-muted)]">
      {siteConfig.nav.map((item) => (
        <a
          href={item.href}
          class={`rounded-full px-4 py-2 transition hover:bg-[var(--brand-soft)] hover:text-[var(--brand)] ${
            isActive(item.href) ? 'bg-[var(--brand)] text-[var(--brand-foreground)] hover:bg-[var(--brand)] hover:text-[var(--brand-foreground)]' : ''
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
